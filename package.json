{
  "name": "plynth",
  "version": "0.1.0",
  "description": "Plaid transaction sync for developers — wire it up once, query Postgres directly.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:integration": "DATABASE_URL=postgres://localhost/plynth_test jest test/integration.test.ts",
    "test:plaid": "jest test/plaid.integration.test.ts --testTimeout=30000"
  },
  "keywords": [
    "plaid",
    "transactions",
    "sync",
    "postgres"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pg": "^8.11.0",
    "plaid": "^26.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "dotenv": "^17.4.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "setupFiles": ["./test/setup.ts"]
  }
}
